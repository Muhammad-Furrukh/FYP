        <mxCell id="wtadDzqarJSNFot-p4i7-27" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="issue_wr_en" vertex="1">
